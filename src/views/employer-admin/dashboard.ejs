<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow mb-4">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">Control Panel</h2>
                </div>
                <div class="card-body">
                    <h4>Welcome, <%= user.email %>!</h4>
                    <p class="text-muted">Manage your job vacancies, blog posts, and candidates from here.</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-4">
                            <a href="/jobs/new" class="btn btn-primary btn-block">Add New Job</a>
                        </div>
                        <div class="col-md-4">
                            <a href="/blog/new" class="btn btn-info btn-block">New Blog Post</a>
                        </div>
                        <% if (user.role === 'admin') { %>
                        <div class="col-md-4">
                            <a href="/candidates" class="btn btn-dark btn-block">Manage All Candidates</a>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-secondary text-white">My Job Listings</div>
                <div class="card-body p-0">
                    <% if (typeof jobs !== 'undefined' && jobs.length > 0) { %>
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Company</th>
                                    <th>Location</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% jobs.forEach(job => { %>
                                    <tr>
                                        <td><strong><%= job.title %></strong></td>
                                        <td><%= job.company %></td>
                                        <td><%= job.location %></td>
                                        <td>
                                            <a href="/jobs/<%= job.id %>/candidates" class="btn btn-sm btn-info">Candidates</a>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div class="p-4 text-center text-muted">
                            You have no job vacancies yet.
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>