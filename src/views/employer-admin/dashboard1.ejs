<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">Control Panel</h2>
                    <span class="badge badge-info"><%= user.role.toUpperCase() %></span>
                </div>
                <div class="card-body">
                    <h4>Welcome, <%= user.email %>!</h4>
                    <p class="text-muted">Manage your job vacancies, blog posts, and candidates from here.</p>
                    <hr>

                    <div class="row text-center mt-4">
                        <div class="col-md-4 mb-3">
                            <div class="p-3 border rounded bg-light">
                                <i class="fas fa-briefcase fa-2x mb-2 text-primary"></i>
                                <h5>Vacancies</h5>
                                <a href="/jobs/new" class="btn btn-primary btn-block">Add New Job</a>
                                <a href="/jobs/my-jobs" class="btn btn-outline-primary btn-block mt-2">View All Jobs</a>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <div class="p-3 border rounded bg-light">
                                <i class="fas fa-edit fa-2x mb-2 text-info"></i>
                                <h5>Blog</h5>
                                <a href="/blog/new" class="btn btn-info btn-block">New Blog Post</a>
                            </div>
                        </div>

                        <% if (user.role === 'admin') { %>
                        <div class="col-md-4 mb-3">
                            <div class="p-3 border rounded bg-warning shadow-sm">
                                <i class="fas fa-users-cog fa-2x mb-2 text-dark"></i>
                                <h5>Administration</h5>
                                <a href="/candidates" class="btn btn-dark btn-block">Manage All Candidates</a>
                                <a href="/admin/add-employer" class="btn btn-outline-dark btn-block mt-2">Manage Employers</a>
                            </div>
                        </div>
                        <% } %>
                    </div>
<% if (typeof jobs !== 'undefined' && jobs.length > 0) { %>
    <div class="mt-5">
        <h4 class="mb-3">Your Job Listings</h4>
        <table class="table table-hover border">
            <thead class="thead-light">
                <tr>
                    <th>Title</th>
                    <th>Company</th>
                    <th>Location</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% jobs.forEach(job => { %>
                    <tr>
                        <td><strong><%= job.title %></strong></td>
                        <td><%= job.company %></td>
                        <td><%= job.location %></td>
                        <td>
                            <a href="/jobs/<%= job.id %>/candidates" class="btn btn-sm btn-info">
                                <i class="fas fa-users"></i> Candidates
                            </a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } else if (typeof jobs !== 'undefined') { %>
    <div class="alert alert-secondary mt-4">
        You haven't posted any jobs yet.
    </div>
<% } %>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <a href="/employer-admin/change-password" class="text-muted"><i class="fas fa-key"></i> Change Password</a>
                        <a href="/employer-admin/logout" class="btn btn-danger">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>